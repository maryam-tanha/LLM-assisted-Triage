# OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Model to use via OpenRouter (provider/model format)
# Examples:
#   openai/gpt-4.1
#   anthropic/claude-sonnet-4-5
#   google/gemini-2.0-flash
LLM_MODEL=openai/gpt-4.1

# Maximum number of tool-call iterations the log agent may use per subtask
MAX_ITERATIONS=10

# Maximum number of specialist nodes that run in parallel (thread pool size)
MAX_CONCURRENCY=10

# Maximum bytes captured from stdout / stderr of each command execution
MAX_OUTPUT_BYTES=65536
STDERR_MAX_BYTES=4096

# Timeout in seconds for a single docker exec command
# Keep this low (5-15s) — commands that hang (e.g. tail /proc/1/fd/1) will block
# for the full duration before the LLM gets an error signal and tries something else.
DOCKER_EXEC_TIMEOUT=10

# Lines of container stdout/stderr to fetch via docker logs as initial LLM context
DOCKER_LOGS_TAIL=200
