# -----------------------------------------------------------------------
# docker-mailserver configuration
# Full reference: https://docker-mailserver.github.io/docker-mailserver/latest/config/environment/
# -----------------------------------------------------------------------

# ── General ─────────────────────────────────────────────────────────────
OVERRIDE_HOSTNAME=mail.example.test
DMS_DEBUG=0
LOG_LEVEL=info
ONE_DIR=1                    # store all state in /var/mail-state (single volume)

# ── Protocols ────────────────────────────────────────────────────────────
SMTP_ONLY=0                  # enable both SMTP and IMAP (Dovecot)
ENABLE_IMAP=1
ENABLE_POP3=0                # disable POP3 (IMAP is sufficient for testing)

# ── TLS ──────────────────────────────────────────────────────────────────
# Use 'self-signed' for local testing — avoids needing real certs
SSL_TYPE=self-signed

# ── Authentication ────────────────────────────────────────────────────────
ENABLE_SASLAUTHD=0
ENABLE_OAUTH2=0

# ── Anti-spam / Anti-virus (disabled for test env to reduce overhead) ─────
ENABLE_SPAMASSASSIN=0
ENABLE_CLAMAV=0
ENABLE_FAIL2BAN=0
ENABLE_POSTGREY=0
ENABLE_AMAVIS=0

# ── Relay / Network ──────────────────────────────────────────────────────
# Allow relay from Docker internal network (avoids auth for internal senders)
PERMIT_DOCKER=network
# Reject unknown recipients — good for catching misconfigured tests
SPOOF_PROTECTION=0
ENABLE_SRS=0

# ── Postfix tuning ──────────────────────────────────────────────────────
POSTFIX_MAILBOX_SIZE_LIMIT=51200000     # 50MB per mailbox
POSTFIX_MESSAGE_SIZE_LIMIT=25600000     # 25MB per message
POSTFIX_INET_PROTOCOLS=ipv4            # ipv4 only inside Docker

# ── Dovecot tuning ──────────────────────────────────────────────────────
DOVECOT_MAILBOX_FORMAT=maildir
MOVE_SPAM_TO_JUNK=0

# ── Logging ─────────────────────────────────────────────────────────────
# Logs go to /var/log/mail/ inside container; also visible via docker logs
LOGROTATE_INTERVAL=weekly
LOGROTATE_COUNT=4
